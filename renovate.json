{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "labels": [
    "dependencies",
    "Skip Changelog"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "ignorePaths": [
    "**/test-requirements.txt",
    "**/pyproject.toml"
  ],
  "github-actions": {
    "managerFilePatterns": [
      "(^|/)\\.github/workflows/templates/[^/]+\\.yml\\.j2$"
    ]
  },
  "packageRules": [
    {
      "matchFileNames": ["docs/**"],
      "groupName": "docs weekly updates",
      "schedule": ["before 4am on Monday"]
    },
    {
      "groupName": "build and infra weekly updates",
      "matchManagers": [
        "github-actions",
        "dockerfile",
        "docker-compose"
      ],
      "schedule": ["before 5am on Monday"]
    },
    {
      "groupName": "all patch versions",
      "matchUpdateTypes": ["patch"],
      "schedule": ["before 6am every weekday"]
    },
    {
      "matchUpdateTypes": ["minor","major"],
      "schedule": ["before 8am on Monday"]
    }
  ]
}
